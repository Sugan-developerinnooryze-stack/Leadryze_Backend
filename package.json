{
  "name": "leadryze-backend",
  "version": "1.0.0",
  "description": "LeadRyze AI Backend API — Multi-tenant lead capture platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node -e \"const {execSync}=require('child_process');try{const r=execSync('netstat -ano').toString();r.split('\\n').filter(l=>l.includes(':5000')).forEach(l=>{const p=l.trim().split(/\\s+/).pop();try{execSync('taskkill /F /PID '+p)}catch(e){}});}catch(e){}\" && nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node --transpile-only src/seed.ts",
    "seed:crm": "ts-node --transpile-only src/seed-native-crm.ts",
    "seed:branches": "ts-node --transpile-only src/seed-branches.ts",
    "seed:crm:innooryze": "cross-env TENANT_SLUG=innooryze-5907b5 ts-node --transpile-only src/seed-native-crm.ts",
    "seed:crm:dinesh": "cross-env TENANT_SLUG=dinesh-company-fefeca ts-node --transpile-only src/seed-native-crm.ts",
    "fix-user": "ts-node --transpile-only src/fix-user.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest --testPathPatterns=security.test.ts",
    "test:all": "jest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/lib-storage": "^3.1083.0",
    "@getbrevo/brevo": "^5.0.4",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.37.0",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "openai": "^4.53.0",
    "pg": "^8.22.0",
    "puppeteer": "^25.3.0",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.12",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
