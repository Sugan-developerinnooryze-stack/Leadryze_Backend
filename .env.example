# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
FRONTEND_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:5001
# Public URL of THIS backend — required in production so uploaded file URLs
# (logos, attachments, etc. served via /api/v1/storage/*) point at the real
# deployed backend instead of falling back to localhost. On Render this is
# your backend service's onrender.com URL, e.g. https://leadryze-backend.onrender.com
BACKEND_URL=http://localhost:5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:changeme@localhost:27017/leadryze?authSource=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-minimum-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=LeadRyze AI

# ─── WhatsApp (Meta WA Cloud API) ────────────────────────────────────────────
META_WA_PHONE_NUMBER_ID=your-phone-number-id
META_WA_ACCESS_TOKEN=your-whatsapp-access-token
META_WA_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-meta-app-secret

# ─── Meta (Instagram / Messenger) ────────────────────────────────────────────
META_IG_ACCESS_TOKEN=your-instagram-access-token
META_PAGE_ID=your-facebook-page-id

# ─── Twilio (Phone / SMS) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── CRM — HubSpot ───────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:5000/api/v1/connectors/hubspot/callback

# ─── CRM — Zoho ──────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# ─── CRM — Salesforce ────────────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret

# ─── Calendar — Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/google/callback

# ─── Calendar — Outlook ──────────────────────────────────────────────────────
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret

# ─── AI Internal Service ─────────────────────────────────────────────────────
AI_INTERNAL_API_KEY=internal-service-api-key-change-this-in-production

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Supabase S3 Storage ─────────────────────────────────────────────────────
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1
SUPABASE_S3_BUCKET=Leadryze_Bucket
SUPABASE_S3_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET=your-s3-secret-access-key
SUPABASE_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public
